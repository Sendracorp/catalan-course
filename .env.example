# ── Supabase (auth + database) ────────────────────────────────────────────
# Create a project at https://supabase.com, then: Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
# Service role key — server only, never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# ── Paddle (payments, merchant of record) ─────────────────────────────────
# https://vendors.paddle.com (or sandbox-vendors.paddle.com while testing).
# "sandbox" or "production".
NEXT_PUBLIC_PADDLE_ENV=sandbox
# Developer Tools → Authentication → client-side token (safe to expose).
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=YOUR-CLIENT-TOKEN
# Developer Tools → Notifications → secret key of the /api/webhooks/paddle destination.
PADDLE_WEBHOOK_SECRET=YOUR-WEBHOOK-SECRET
# Price ID (pri_…) of the product for each course (one env var per course slug).
PADDLE_PRICE_CATALAN_A1=YOUR-PRICE-ID

# ── Site ──────────────────────────────────────────────────────────────────
# Used for auth redirects and checkout return URLs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Local QA only — never set in production ───────────────────────────────
# COURSE_BYPASS_PAYWALL=true
